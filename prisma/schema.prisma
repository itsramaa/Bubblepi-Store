generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockStatus {
  AVAILABLE
  ASSIGNED
  DELIVERED
  EXPIRED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  FULFILLED
  FAILED
  PENDING_STOCK
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  image       String
  category    String
  type        String    @default("sharing") // "sharing" | "private"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  variants    Variant[]
  reviews     Review[]
}

model Variant {
  id            String         @id @default(cuid())
  productId     String
  name          String
  duration      String
  price         Int            // IDR integer
  hasWarranty   Boolean        @default(false)
  warrantyDays  Int?
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock         AccountStock[]
  orderItems    OrderItem[]
}

model AccountStock {
  id          String      @id @default(cuid())
  variantId   String
  credentials String      // plaintext for MVP (ponytail: AES-256 post-MVP)
  status      StockStatus @default(AVAILABLE)
  orderId     String?
  assignedAt  DateTime?
  expiresAt   DateTime?   // optional expiry date for credentials
  createdAt   DateTime    @default(now())
  variant     Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order       Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId, status])
  @@index([orderId])
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique // BP-XXXXXXXX
  customerEmail    String
  customerName     String
  status           OrderStatus @default(PENDING)
  paymentMethod    String?     // "QRIS" | "VA"
  xenditInvoiceId  String?
  xenditPaymentUrl String?
  cancelReason     String?
  subtotal         Int         // IDR integer
  tax              Int         // IDR integer
  total            Int         // IDR integer
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  paidAt           DateTime?
  voucherId        String?
  discountAmount   Int         @default(0)
  resendCount      Int         @default(0)
  items            OrderItem[]
  stocks           AccountStock[]
  review           Review?
  referrals        Referral[]
  warrantyClaims   WarrantyClaim[]
  voucher          Voucher?    @relation(fields: [voucherId], references: [id], onDelete: SetNull)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  price     Int     // price snapshot at time of order
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   Variant @relation(fields: [variantId], references: [id])
  warrantyClaims WarrantyClaim[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  orderId   String   @unique
  rating    Int
  comment   String
  isVisible Boolean  @default(true)
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([productId, isVisible])
}

model Referral {
  id              String   @id @default(cuid())
  referrerEmail   String
  referredEmail   String
  orderId         String   @unique
  status          String   @default("PENDING") // PENDING, CONFIRMED, PAID_OUT
  commissionValue Int      @default(0)
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([referrerEmail])
}

enum WarrantyStatus {
  PENDING
  APPROVED
  REJECTED
}

model WarrantyClaim {
  id            String        @id @default(cuid())
  orderId       String
  orderItemId   String
  description   String
  status        WarrantyStatus @default(PENDING)
  resolveNote   String?
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderId, orderItemId])
  @@index([orderId])
}

model AbandonedCart {
  id        String   @id @default(cuid())
  email     String
  name      String?
  items     String   // JSON array of cart items
  recovered Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, recovered])
}

model Voucher {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // PERCENT | FIXED
  value     Int
  minOrder  Int       @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  orders    Order[]

  @@index([code])
}
