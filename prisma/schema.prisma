generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  USER
  ADMIN
}

enum StockStatus {
  AVAILABLE
  HOLD
  SOLD
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  DELIVERED
  FAILED
  EXPIRED
}

enum PaymentMethod {
  QRIS
  VIRTUAL_ACCOUNT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum WarrantyStatus {
  ACTIVE
  CLAIMED
  EXPIRED
}

enum ClaimStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum SupplierType {
  TELEGRAM_BOT
  API
}

// ==================== MODELS ====================

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(USER)
  orders       Order[]
  warranties   Warranty[]
  testimonials Testimonial[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reviews      Review[]
}

model Product {
  id              String           @id @default(cuid())
  supplierId      String? // Link to Supplier, null = manual
  name            String
  slug            String           @unique
  description     String?
  image           String?
  category        String?
  isActive        Boolean          @default(true) // Admin can toggle display
  warrantyOptions WarrantyOption[]
  variants        Variant[]
  orders          Order[]
  warranties      Warranty[]
  reviews         Review[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  testimonials    Testimonial[]
}

model Variant {
  id                     String                  @id @default(cuid())
  productId              String
  name                   String // "1 Bulan", "3 Bulan", "1 Tahun"
  price                  Int // IDR, dari Sheets
  supplierVariantId      String? // ID di supplier
  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks                 AccountStock[]
  orderItems             OrderItem[]
  warrantyOptions        WarrantyOption[]
  warrantyClaims         WarrantyClaim[]
  supplierProducts       SupplierProduct[]
  priceDropNotifications PriceDropNotification[]
  warranties             Warranty[]
}

model WarrantyOption {
  id        String   @id @default(cuid())
  productId String
  duration  Int // 0, 7, 30 hari
  price     Int // IDR, fixed price dari Sheets
  terms     String? // S&K per produk
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   Variant? @relation(fields: [variantId], references: [id])
  variantId String?

  @@unique([productId, duration])
}

model AccountStock {
  id          String      @id @default(cuid())
  variantId   String
  credentials String // encrypted via AES-256
  status      StockStatus @default(AVAILABLE)
  supplierId  String? // dari supplier mana
  orderId     String?
  acquiredAt  DateTime    @default(now())
  soldAt      DateTime?
  variant     Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order       Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId, status])
  @@index([orderId])
}

model Order {
  id               String         @id @default(cuid())
  orderNumber      String         @unique // BP-XXXXXXXX
  userId           String? // Nullable: guest checkout
  guestEmail       String? // Untuk guest
  guestName        String? // Untuk guest
  status           OrderStatus    @default(PENDING)
  paymentMethod    PaymentMethod?
  paymentStatus    PaymentStatus  @default(PENDING)
  xenditInvoiceId  String?
  xenditPaymentUrl String?
  subtotal         Int // IDR integer
  total            Int // IDR integer
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  paidAt           DateTime?
  cancelReason     String? // Alasan pembatalan

  // Relations
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  stocks         AccountStock[]
  warranty       Warranty?
  warrantyClaims WarrantyClaim[]
  review         Review?
  product        Product?        @relation(fields: [productId], references: [id])
  productId      String?
  referral       Referral?
  voucher        Voucher?        @relation(fields: [voucherId], references: [id])
  voucherId      String?
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  variantId        String
  warrantyOptionId String? // Nullable: tanpa garansi
  quantity         Int
  price            Int // price snapshot (variant price + warranty)
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant          Variant         @relation(fields: [variantId], references: [id])
  warrantyClaims   WarrantyClaim[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  orderId   String   @unique
  userId    String
  rating    Int
  comment   String
  isVisible Boolean  @default(true)
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([productId, isVisible])
}

model Referral {
  id              String   @id @default(cuid())
  referrerEmail   String
  referredEmail   String
  orderId         String   @unique
  status          String   @default("PENDING") // PENDING, CONFIRMED, PAID_OUT
  commissionValue Int      @default(0)
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([referrerEmail])
}

model Warranty {
  id               String          @id @default(cuid())
  orderId          String          @unique
  userId           String
  productId        String
  variantId        String
  warrantyOptionId String // 0, 7, 30 hari
  duration         Int // durasi dalam hari
  startDate        DateTime? // tanggal delivery
  expiryDate       DateTime? // startDate + duration
  status           WarrantyStatus  @default(ACTIVE)
  claimCount       Int             @default(0) // max 1x per warranty
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  variant          Variant         @relation(fields: [variantId], references: [id])
  claims           WarrantyClaim[]
}

model WarrantyClaim {
  id                String      @id @default(cuid())
  warrantyId        String
  proofImageUrl     String? // screenshot bukti error
  proofImageExpiry  DateTime? // 24 jam setelah submission
  claimReason       String? // alasan klaim
  status            ClaimStatus @default(PENDING_REVIEW)
  rejectionReason   String?
  submittedAt       DateTime    @default(now())
  reviewedAt        DateTime?
  warranty        Warranty    @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
  variant         Variant?    @relation(fields: [variantId], references: [id])
  variantId       String?
  order           Order?      @relation(fields: [orderId], references: [id])
  orderId         String?
  orderItem       OrderItem?  @relation(fields: [orderItemId], references: [id])
  orderItemId     String?

  @@index([warrantyId])
  @@index([status])
}

model AbandonedCart {
  id        String   @id @default(cuid())
  email     String
  name      String?
  items     String // JSON array of cart items
  recovered Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, recovered])
}

model Voucher {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String // PERCENT | FIXED
  value     Int
  minOrder  Int       @default(0)
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  orders    Order[]

  @@index([code])
}

model FunnelEvent {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  event     String // VIEW_PRODUCT | ADD_TO_CART | CHECKOUT_START | PAYMENT_INITIATED | PAYMENT_SUCCESS
  productId String?  @map("product_id")
  variantId String?  @map("variant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([event, createdAt])
  @@map("funnel_events")
}

model Supplier {
  id        String            @id @default(cuid())
  name      String // display name e.g. "Barbar Store"
  type      SupplierType // TELEGRAM_BOT or API
  config    Json // { botToken?, apiKey?, serviceUrl?, etc }
  isActive  Boolean           @default(true)
  priority  Int               @default(0) // 0 = primary, higher = fallback
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  products  SupplierProduct[]
}

model SupplierProduct {
  id           String   @id @default(cuid())
  supplierId   String
  variantId    String // Bubblepi Variant.id
  productBotId String // supplier internal product ID e.g. "7791"
  variantBotId String // supplier internal variant ID e.g. "29397"
  label        String // e.g. "CAPCUT PRO - 7 DAY PRIVATE"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variant      Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([supplierId, variantId])
  @@index([variantId])
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String?  // Nullable for guest testimonials
  productId String?
  rating    Int // 1-5
  comment   String
  isVisible Boolean  @default(true)
  isPinned  Boolean  @default(false) // featured di atas review lain
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isVisible])
}

model PriceDropNotification {
  id          String   @id @default(cuid())
  email       String
  variantId   String   @map("variant_id")
  targetPrice Int?     @map("target_price") // null = notify on any price drop
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([email, variantId])
  @@index([variantId, notified])
  @@map("price_drop_notifications")
}
