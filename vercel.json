{
  "buildCommand": "prisma generate && next build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/check-expired-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/retry-emails",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/low-stock-alert",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/auto-expire",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/auto-retry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/auto-cancel",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/auto-cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/renewal-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/stok-kritis",
      "schedule": "0 */4 * * *"
    }
  ]
}
