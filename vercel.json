{
  "buildCommand": "prisma generate && next build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/check-expired-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/retry-emails",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/low-stock-alert",
      "schedule": "0 */6 * * *"
    }
  ]
}
